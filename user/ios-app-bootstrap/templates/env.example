# Copy to .env (gitignored) and fill in — needed for local fastlane runs.

# Team ID: developer.apple.com -> Membership details
APPLE_TEAM_ID=

# App Store Connect -> Users and Access -> Integrations -> App Store Connect API
ASC_KEY_ID=
ASC_ISSUER_ID=
# base64 of the downloaded key: base64 -i AuthKey_XXXXXXXXXX.p8
ASC_KEY_CONTENT=

# Encryption password for the certificates repo (invent once; also goes into GitHub secrets)
MATCH_PASSWORD=
